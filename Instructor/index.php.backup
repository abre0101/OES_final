<?php
session_start();
if(!isset($_SESSION['Name'])){
    header("Location:../auth/institute-login.php");
    exit();
}

$con = require_once(__DIR__ . "/../Connections/OES.php");
$pageTitle = "My Courses";
$instructor_id = $_SESSION['ID'];

// Get filter parameters
$department_filter = $_GET['department'] ?? '';
$semester_filter = $_GET['semester'] ?? '';

// Get instructor's courses with statistics
$query = "SELECT 
    c.course_id,
    c.course_code,
    c.course_name,
    c.credit_hours,
    c.semester,
    d.department_id,
    d.department_name,
    f.faculty_name,
    COUNT(DISTINCT sc.student_id) as student_count,
    COUNT(DISTINCT q.question_id) as question_count,
    COUNT(DISTINCT es.exam_id) as exam_count,
    COUNT(DISTINCT CASE WHEN es.approval_status = 'approved' THEN es.exam_id END) as approved_exams,
    COUNT(DISTINCT er.result_id) as result_count,
    AVG(er.percentage_score) as avg_score
    FROM instructor_courses ic
    INNER JOIN courses c ON ic.course_id = c.course_id
    INNER JOIN departments d ON c.department_id = d.department_id
    INNER JOIN faculties f ON d.faculty_id = f.faculty_id
    LEFT JOIN student_courses sc ON c.course_id = sc.course_id
    LEFT JOIN questions q ON c.course_id = q.course_id AND q.created_by = ?
    LEFT JOIN exams es ON c.course_id = es.course_id AND es.created_by = ?
    LEFT JOIN exam_results er ON es.exam_id = er.exam_id
    WHERE ic.instructor_id = ?";

$params = [$instructor_id, $instructor_id, $instructor_id];
$types = "iii";

if($department_filter) {
    $query .= " AND d.department_id = ?";
    $params[] = $department_filter;
    $types .= "i";
}

if($semester_filter) {
    $query .= " AND c.semester = ?";
    $params[] = $semester_filter;
    $types .= "s";
}

$query .= " GROUP BY c.course_id ORDER BY c.course_name";

$stmt = $con->prepare($query);
$stmt->bind_param($types, ...$params);
$stmt->execute();
$courses = $stmt->get_result();

// Get departments for filter
$deptQuery = $con->prepare("SELECT DISTINCT d.department_id, d.department_name
    FROM instructor_courses ic
    INNER JOIN courses c ON ic.course_id = c.course_id
    INNER JOIN departments d ON c.department_id = d.department_id
    WHERE ic.instructor_id = ?
    ORDER BY d.department_name");
$deptQuery->bind_param("i", $instructor_id);
$deptQuery->execute();
$departments = $deptQuery->get_result();

// Get overall statistics
$statsQuery = $con->prepare("SELECT 
    COUNT(DISTINCT c.course_id) as total_courses,
    COUNT(DISTINCT sc.student_id) as total_students,
    COUNT(DISTINCT q.question_id) as total_questions,
    COUNT(DISTINCT es.exam_id) as total_exams
    FROM instructor_courses ic
    INNER JOIN courses c ON ic.course_id = c.course_id
    LEFT JOIN student_courses sc ON c.course_id = sc.course_id
    LEFT JOIN questions q ON c.course_id = q.course_id AND q.created_by = ?
    LEFT JOIN exams es ON c.course_id = es.course_id AND es.created_by = ?
    WHERE ic.instructor_id = ?");
$statsQuery->bind_param("iii", $instructor_id, $instructor_id, $instructor_id);
$statsQuery->execute();
$stats = $statsQuery->get_result()->fetch_assoc();
?>
